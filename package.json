{
  "name": "internet-computing-backend",
  "version": "0.1.0",
  "description": "Backend server for the CP476 Course Registration Dashboard (Node.js, Express, MySQL).",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand tests/unit",
    "test:integration": "cross-env NODE_ENV=test jest --runInBand --forceExit tests/integration",
    "db:init": "node scripts/init-db.js",
    "db:seed": "node scripts/seed.js",
    "admin:create": "node scripts/create-admin.js"
  },
  "keywords": [
    "express",
    "mysql",
    "course-registration",
    "cp476"
  ],
  "author": "NickKL05",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
